aws_region         = "eu-central-1"
project            = "platform"
environment        = "sandbox"
cluster_name       = "eks-fargate"
kubernetes_version = "1.33"
az_count           = 3
vpc_cidr           = "10.40.0.0/16"

fargate_namespaces = ["kube-system", "argocd", "app"]
gitops_lab_namespace = "demo"

enable_gitops_lab_ecr_repositories = true
gitops_lab_ecr_repository_prefix    = "gitops-lab"

enable_aws_load_balancer_controller = true
aws_load_balancer_controller_namespace = "kube-system"

enable_argocd              = true
argocd_namespace           = "argocd"
argocd_hostname            = ""           # e.g. argocd.example.com
argocd_alb_scheme          = "internet-facing"
argocd_alb_certificate_arn = ""           # ACM ARN for HTTPS; leave empty for HTTP-only

# S3 backend — bucket name must be globally unique; include account ID or team prefix
tfstate_bucket_name     = "platform-eks-fargate-tfstate-eu-central-1"
tfstate_lock_table_name = "platform-eks-fargate-tfstate-lock"

tags = {
  Owner      = "platform-team"
  CostCenter = "1234"
}
